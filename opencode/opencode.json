{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen3:8b-fast",
  "provider": {
    "anthropic": {
      "models": {
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (cheap/fast)",
          "reasoning": false,
          "tools": true
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (balance)",
          "reasoning": true,
          "tools": true
        }
      },
      "name": "Anthropic",
      "npm": "@ai-sdk/anthropic"
    },
    "deepseek": {
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek V3 (best value)",
          "reasoning": false,
          "tools": true
        },
        "deepseek-reasoner": {
          "name": "DeepSeek R1 (reasoning)",
          "reasoning": true,
          "tools": false
        }
      },
      "name": "DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "${DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com/v1"
      }
    },
    "groq": {
      "models": {
        "deepseek-r1-distill-llama-70b": {
          "name": "DeepSeek R1 70B Distill (reasoning)",
          "reasoning": true,
          "tools": false
        },
        "llama-3.3-70b-versatile": {
          "name": "Llama 3.3 70B (free/fast)",
          "reasoning": false,
          "tools": true
        },
        "qwen-qwq-32b": {
          "name": "Qwen QwQ 32B (reasoning)",
          "reasoning": true,
          "tools": false
        }
      },
      "name": "Groq",
      "npm": "@ai-sdk/groq"
    },
    "ollama": {
      "models": {
        "mfdoom/deepseek-r1-tool-calling:8b": {
          "name": "DeepSeek-R1 8B (reasoning + tools)",
          "reasoning": true,
          "tools": true
        },
        "kimi-k2.5:cloud": {
          "name": "Kimi K2.5 (cloud)",
          "reasoning": true,
          "tools": true
        },
        "minimax-m2.5:cloud": {
          "name": "MiniMax M2.5 (cloud)",
          "reasoning": true,
          "tools": true
        },
        "phi4-mini:latest": {
          "name": "Phi-4 Mini (fast/small)",
          "reasoning": false,
          "tools": false
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5-Coder 14B (coding)",
          "reasoning": false,
          "tools": true
        },
        "qwen3:8b": {
          "maxTokens": 500,
          "name": "Qwen3 8B (40k ctx - TOO SLOW, use -fast or -code)",
          "reasoning": false,
          "tools": true
        },
        "qwen3:8b-fast": {
          "maxTokens": 500,
          "name": "Qwen3 8B Fast (4k ctx - quick queries)",
          "reasoning": false,
          "tools": true
        },
        "qwen3:8b-code": {
          "maxTokens": 500,
          "name": "Qwen3 8B Code (8k ctx - coding tasks)",
          "reasoning": false,
          "tools": true
        },
        "qwen3.5:cloud": {
          "name": "Qwen3.5 (cloud)",
          "reasoning": true,
          "tools": true
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
