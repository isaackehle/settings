{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "code": {
      "description": "Primary coding agent for implementation, editing, refactoring, and debugging.",
      "maxTokens": 16000,
      "mode": "primary",
      "model": "litellm/qwen3.5-27b-q8-256k",
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are the main coding agent. Focus on implementation, refactoring, debugging, and precise code changes. Prefer minimal diffs, preserve existing architecture unless there is a clear reason to change it, and explain tradeoffs briefly.",
      "temperature": 0.2
    },
    "local": {
      "description": "Fully local agent — no cloud calls, no webfetch. Use for sensitive or offline work.",
      "maxTokens": 8000,
      "mode": "primary",
      "model": "litellm/qwen3-coder-30b-q5-32k",
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "deny"
      },
      "prompt": "You are a fully local coding agent with no internet access. Work only with files and context provided. Be explicit when you need information you cannot access.",
      "temperature": 0.2
    },
    "plan": {
      "description": "Fast planning agent for next steps, breakdowns, and lightweight routing.",
      "mode": "primary",
      "model": "litellm/qwen3-4b-q8-256k",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a lightweight planning agent. Turn goals into actionable steps, break work into phases, identify blockers, and recommend the next best action. Stay concise, practical, and execution-oriented.",
      "temperature": 0.25
    },
    "research": {
      "description": "Research agent for company research, technical discovery, and structured findings.",
      "mode": "primary",
      "model": "litellm/qwen3-14b-q5-40k",
      "permission": {
        "bash": "deny",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a research agent. Gather evidence, inspect files, compare options, and produce structured findings. Do not execute shell commands.\n\nAt the end of every research session, save your findings to the Obsidian vault at:\n  ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/primary/Research/\n\nName the file using the topic and today's date: `YYYY-MM-DD topic-slug.md`.",
      "temperature": 0.25
    },
    "think": {
      "description": "Reasoning agent for decision analysis, scoring, debugging strategy, and debriefs.",
      "mode": "primary",
      "model": "openrouter/deepseek/deepseek-r1-tool-calling-32b",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a read-only reasoning agent. Provide concise, stepwise analysis of tradeoffs, debugging hypotheses, architectural choices, interview answers, and evaluation decisions. Do not edit files or run commands.",
      "temperature": 0.3
    },
    "write": {
      "description": "Writing agent for resumes, cover letters, documentation, summaries, and polished prose.",
      "mode": "primary",
      "model": "litellm/qwen3.5-27b-q8-256k",
      "permission": {
        "bash": "deny",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a writing-focused agent. Optimize for clarity, tone, structure, and persuasive but concrete language. Produce polished resumes, cover letters, technical documentation, summaries, and interview prep materials.",
      "temperature": 0.65
    }
  },
  "default_agent": "code",
  "model": "litellm/qwen3.5-27b-q8-256k",
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "webfetch": "allow"
  },
    "provider": {
    "litellm": {
      "models": {
        "qwen3.5-27b-q8-256k": {
          "name": "Qwen3.5 27B Q8 (256k)"
        },
        "qwen3-coder-30b-q5-32k": {
          "name": "Qwen3 Coder 30B Q5 (32k)"
        },
        "qwen3-4b-q8-256k": {
          "name": "Qwen3 4B Q8 (256k)"
        },
        "qwen3-14b-q5-40k": {
          "name": "Qwen3 14B Q5 (40k)"
        }
      },
      "name": "LiteLLM (Proxy)",
      // LiteLLM proxy — provides access to ollama server models (port 11434) via litellm.
      // Start litellm proxy first; see litellm.sh for setup.
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "sk-local",
        "baseURL": "http://localhost:4000/v1"
      }
    }
  },
    "ollama": {
      "models": {
        "codestral-22b:q6-32k": {
          "name": "Codestral 22b (q6-32k)"
        },
        "deepseek-r1:14b": {
          "name": "DeepSeek R1 14B"
        },
        "deepseek-r1-14b:q8-128k": {
          "name": "DeepSeek R1 8B (q8 128k)"
        },
        "gemma3:12b": {
          "name": "Gemma3 12b"
        },
        "gemma4:26b": {
          "name": "Gemma4 26b"
        },
        "glm-4.7-flash:latest": {
          "name": "GLM 4.7 Flash (q4-198k)"
        },
        "glm-4.7-flash:q8-198k": {
          "name": "GLM 4.7 Flash (q8-198k)"
        },
        "gpt-oss:latest": {
          "name": "GPT-OSS (14b)"
        },
        "llama3.2:latest": {
          "name": "Llama3.2 (latest)"
        },
        "llama3.3:70b": {
          "name": "Llama3.3 70b"
        },
        "nomic-embed-text:latest": {
          "name": "Nomic Embed Text (latest)"
        },
        "phi4:latest": {
          "name": "Phi4 14b (q4-16k)"
        },
        "phi4-14b:q8-16k": {
          "name": "Phi4 14b (q8-16k)"
        },
        "qwen2.5-coder-7b:q8-32k": {
          "name": "Qwen2.5 Coder 7b (q8-32k)"
        },
        "qwen2.5-coder:1.5b": {
          "name": "Qwen2.5 Coder 1.5b (q4-32k)"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5 Coder 7b (q4-32k)"
        },
        "qwen3-14b:q5-40k": {
          "name": "Qwen3 14b (q5-40k)"
        },
        "qwen3-14b:q8-40k": {
          "name": "Qwen3 14b (q8-40k)"
        },
        "qwen3-32b:q5-32k": {
          "name": "Qwen3 32b (q5-32k)"
        },
        "qwen3-4b:q8-256k": {
          "name": "Qwen3 4b (q8-256k)"
        },
        "qwen3-coder-30b-a3b:q5-128k": {
          "name": "Qwen3 Coder 30b (q5-128k)"
        },
        "qwen3-coder-30b-a3b:q5-256k": {
          "name": "Qwen3 Coder 30b A3B (q5-256k)"
        },
        "qwen3-coder-30b-a3b:q5-32k": {
          "name": "Qwen3 Coder 30b A3B (q5-32k)"
        },
        "qwen3-coder-30b-a3b:q5-8k": {
          "name": "Qwen3 Coder 30b A3B (q5-8k)"
        },
        "qwen3.5-27b:q5-128k": {
          "name": "Qwen3.5 27b (q5-128k)"
        },
        "qwen3.5-27b:q5-256k": {
          "name": "Qwen3.5 27b (q5-256k)"
        },
        "qwen3.5-27b:q5-32k": {
          "name": "Qwen3.5 27b (q5-32k)"
        },
        "qwen3.5-27b:q5-8k": {
          "name": "Qwen3.5 27b (q5-8k)"
        },
        "qwen3.5-27b:q8-128k": {
          "name": "Qwen3.5 27b (q8-128k)"
        },
        "qwen3.5-27b:q8-256k": {
          "name": "Qwen3.5 27b (q8-256k)"
        },
        "qwen3.5-27b:q8-32k": {
          "name": "Qwen3.5 27b (q8-32k)"
        },
        "qwen3.5-27b:q8-8k": {
          "name": "Qwen3.5 27b (q8-8k)"
        },
        "qwen3.6-35b:q4-128k": {
          "name": "Qwen3.6 35b (q4-128k)"
        },
        "qwen3.6-35b:q4-256k": {
          "name": "Qwen3.6 35b (q4-256k)"
        },
        "qwen3.6-35b:q4-32k": {
