        "qwen3.6-35b:q4-8k": {
          "name": "Qwen3.6 35b (q4-8k)"
        }
      },
      "name": "Ollama (Local)",
      "npm": "@ai-sdk/ollama",
      "options": {
        "baseURL": "http://localhost:11434"
      }
    },
    "openrouter": {
      "models": {
        "anthropic/claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        },
        "anthropic/claude-opus-4-6": {
