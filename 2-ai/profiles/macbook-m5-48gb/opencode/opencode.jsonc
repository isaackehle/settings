        },
        "openai/gpt-4o": {
          "name": "GPT-4o"
        },
        "openai/o3": {
          "name": "OpenAI o3"
        },
        "perplexity/sonar-pro": {
          "name": "Perplexity Sonar Pro"
        },
        "qwen/qwen3-8b": {
          "name": "Qwen3 8B (fast, planning)"
        },
        "qwen/qwen3-coder-next-80b": {
          "name": "Qwen3 Coder Next 80B (code)"
        },
        "thudm/glm-5.1": {
          "name": "GLM 5.1"
        },
        "x-ai/grok-3": {
          "name": "Grok 3"
        },
        "x-ai/grok-3-mini": {
          "name": "Grok 3 Mini"
        }
      },
      "name": "OpenRouter",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "env.OPENROUTER_API_KEY",
        "baseURL": "https://openrouter.ai/api/v1"
      }
    }
  },
  "small_model": "ollama/qwen3-4b:q8-256k"
}
