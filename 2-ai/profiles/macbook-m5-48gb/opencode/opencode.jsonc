{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "code": {
      "description": "Primary coding agent for implementation, editing, refactoring, and debugging.",
      "maxTokens": 16000,
      "mode": "primary",
      "model": "ollama/qwen3-coder-30b-a3b:q5",
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are the main coding agent. Focus on implementation, refactoring, debugging, and precise code changes. Prefer minimal diffs, preserve existing architecture unless there is a clear reason to change it, and explain tradeoffs briefly.",
      "temperature": 0.2
    },
    "local": {
      "description": "Fully local agent — no cloud calls, no webfetch. Use for sensitive or offline work.",
      "maxTokens": 8000,
      "mode": "primary",
      "model": "ollama/qwen3-coder-30b-a3b:q5-32k",
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "deny"
      },
      "prompt": "You are a fully local coding agent with no internet access. Work only with files and context provided. Be explicit when you need information you cannot access.",
      "temperature": 0.2
    },
    "plan": {
      "description": "Fast planning agent for next steps, breakdowns, and lightweight routing.",
      "mode": "primary",
      "model": "ollama/qwen3:4b",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a lightweight planning agent. Turn goals into actionable steps, break work into phases, identify blockers, and recommend the next best action. Stay concise, practical, and execution-oriented.",
      "temperature": 0.25
    },
    "research": {
      "description": "Research agent for company research, technical discovery, and structured findings.",
      "mode": "primary",
      "model": "ollama/qwen3-coder-30b-a3b:q5",
      "permission": {
        "bash": "deny",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a research agent. Gather evidence, inspect files, compare options, and produce structured findings. Do not execute shell commands.\n\nAt the end of every research session, save your findings to the Obsidian vault at:\n  ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/primary/Research/\n\nName the file using the topic and today's date: `YYYY-MM-DD topic-slug.md`.",
      "temperature": 0.25
    },
    "think": {
      "description": "Reasoning agent for decision analysis, scoring, debugging strategy, and debriefs.",
      "mode": "primary",
      "model": "ollama/deepseek-r1-tools:32b",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a read-only reasoning agent. Provide concise, stepwise analysis of tradeoffs, debugging hypotheses, architectural choices, interview answers, and evaluation decisions. Do not edit files or run commands.",
      "temperature": 0.3
    },
    "write": {
      "description": "Writing agent for resumes, cover letters, documentation, summaries, and polished prose.",
      "mode": "primary",
      "model": "ollama/qwen3.5-27b:q8",
      "permission": {
        "bash": "deny",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a writing-focused agent. Optimize for clarity, tone, structure, and persuasive but concrete language. Produce polished resumes, cover letters, technical documentation, summaries, and interview prep materials.",
      "temperature": 0.65
    }
  },
  "default_agent": "code",
  "model": "ollama/qwen3-coder-30b-a3b:q5",
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "ollama": {
      "models": {
        "codestral:22b": { "name": "Codestral 22B (DIFF)" },
        "codestral:22b-32k": { "name": "Codestral 22B (DIFF, 32K)" },
        "deepseek-r1-tools:32b": { "name": "DeepSeek R1 32B (REAS, TOOL)" },
        "deepseek-r1-tools:32b-128k": { "name": "DeepSeek R1 32B (REAS, TOOL, 128K)" },
        "gemma4:31b": { "name": "Gemma 4 31B (REAS)" },
        "gemma4:31b-8k": { "name": "Gemma 4 31B (REAS, 8K)" },
        "gemma4:31b-32k": { "name": "Gemma 4 31B (REAS, 32K)" },
        "gemma4:31b-128k": { "name": "Gemma 4 31B (REAS, 128K)" },
        "nomic-embed-text": { "name": "Nomic Embed Text (EMBD)" },
        "qwen2.5-coder:1.5b": { "name": "Qwen 2.5 Coder 1.5B (FILL)" },
        "qwen2.5-coder:7b": { "name": "Qwen 2.5 Coder 7B (FILL)" },
        "qwen3:4b": { "name": "Qwen 3 4B (PLAN)" },
        "qwen3:4b-8k": { "name": "Qwen 3 4B (PLAN, 8K)" },
        "qwen3:4b-128k": { "name": "Qwen 3 4B (PLAN, 128K)" },
        "qwen3.5-27b:q5": { "name": "Qwen 3.5 27B (WRIT, Q5)" },
        "qwen3.5-27b:q5-8k": { "name": "Qwen 3.5 27B (WRIT, Q5 8K)" },
        "qwen3.5-27b:q5-32k": { "name": "Qwen 3.5 27B (WRIT, Q5 32K)" },
        "qwen3.5-27b:q5-128k": { "name": "Qwen 3.5 27B (WRIT, Q5 128K)" },
        "qwen3.5-27b:q5-256k": { "name": "Qwen 3.5 27B (WRIT, Q5 256K)" },
        "qwen3.5-27b:q8": { "name": "Qwen 3.5 27B (WRIT, Q8)" },
        "qwen3.6-35b:q4": { "name": "Qwen 3.6 35B A3B (CODE, Q4)" },
        "qwen3.6-35b:q4-8k": { "name": "Qwen 3.6 35B A3B (CODE, Q4 8K)" },
        "qwen3.6-35b:q4-128k": { "name": "Qwen 3.6 35B A3B (CODE, Q4 128K)" },
        "qwen3.6-35b:q4-256k": { "name": "Qwen 3.6 35B A3B (CODE, Q4 256K)" },
        "qwen3-coder-30b-a3b:q5": { "name": "Qwen3 Coder 30B A3B (CODE, Q5)" },
        "qwen3-coder-30b-a3b:q5-8k": { "name": "Qwen3 Coder 30B A3B (CODE, Q5 8K)" },
        "qwen3-coder-30b-a3b:q5-32k": { "name": "Qwen3 Coder 30B A3B (CODE, Q5 32K)" },
        "qwen3-coder-30b-a3b:q5-128k": { "name": "Qwen3 Coder 30B A3B (CODE, Q5 128K)" }
      },
      "name": "Ollama (Local)",
      "npm": "@ai-sdk/ollama",
      "options": {
        "baseURL": "http://localhost:11434"
      }
    },
    "openrouter": {
      "models": {
        "anthropic/claude-haiku-4-5": { "name": "Claude Haiku 4.5 (CLD)" },
        "anthropic/claude-opus-4-6": { "name": "Claude Opus 4.6 (CLD)" },
        "anthropic/claude-sonnet-4-6": { "name": "Claude Sonnet 4.6 (CLD)" },
        "deepseek/deepseek-r1-tool-calling-32b": { "name": "DeepSeek R1 Tool Calling 32B (REAS, TOOL, CLD)" },
        "google/gemini-2.5-flash": { "name": "Gemini 2.5 Flash (CLD)" },
        "google/gemini-2.5-pro": { "name": "Gemini 2.5 Pro (REAS, CLD)" },
        "mistralai/mistral-large": { "name": "Mistral Large (CLD)" },
        "moonshot/kimi-k2.6": { "name": "Kimi K2.6 (REAS, CLD)" },
        "openai/gpt-4o": { "name": "GPT-4o (CLD)" },
        "openai/o3": { "name": "OpenAI o3 (CLD)" },
        "perplexity/sonar-pro": { "name": "Perplexity Sonar Pro (CLD)" },
        "qwen/qwen3-8b": { "name": "Qwen3 8B (PLAN, CLD)" },
        "qwen/qwen3-coder-next-80b": { "name": "Qwen3 Coder Next 80B (CODE, CLD)" },
        "thudm/glm-5.1": { "name": "GLM 5.1 (CLD)" },
        "x-ai/grok-3": { "name": "Grok 3 (CLD)" },
        "x-ai/grok-3-mini": { "name": "Grok 3 Mini (CLD)" }
      },
      "name": "OpenRouter",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "env.OPENROUTER_API_KEY",
        "baseURL": "https://openrouter.ai/api/v1"
      }
    }
  },
  "small_model": "ollama/qwen3:4b"
}