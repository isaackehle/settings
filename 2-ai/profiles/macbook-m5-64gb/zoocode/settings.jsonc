{
  // Zoo Code (zooveterinaryinc.zoo-code) — VS Code settings snippet
  // MERGE INTO: ~/Library/Application Support/Code/User/settings.json
  //
  // API config is set via the Zoo Code sidebar → API Provider: OpenAI Compatible
  //   Base URL  → http://localhost:11434/v1
  //   API Key   → sk-local
  //
  // Zoo Code supports per-mode model selection. Recommended assignments:
  //   Code mode      → qwen3-coder-next-80b:q4        (primary coding)
  //   Architect mode → gemma4:31b                      (dense reasoning, vision, planning)
  //   Ask mode       → qwen3.5-27b:q5                  (Q&A, research)
  //   Debug mode     → deepseek-r1-tools:32b           (reasoning + tool calls)
  //
  // Cloud fallback (any mode):
  //   Provider  → OpenRouter
  //   API Key   → $OPENROUTER_API_KEY
  //   Model     → moonshot/kimi-k2.6

  "zoo-code.preferredLanguage": "English",
  "zoo-code.alwaysAllowReadOnly": true,
  "zoo-code.alwaysAllowReadOnlyOutsideWorkspace": false,
  "zoo-code.alwaysAllowWrite": false,
  "zoo-code.alwaysAllowExecute": false,

  // Zoo Code mode-specific model overrides (if supported via settings.json):
  "zoo-code.modeApiConfigs": {
    "code": {
      "apiProvider": "openai",
      "openAiBaseUrl": "http://localhost:11434/v1",
      "openAiApiKey": "sk-local",
      "openAiModelId": "qwen3-coder-next-80b:q4"
    },
    "architect": {
      "apiProvider": "openai",
      "openAiBaseUrl": "http://localhost:11434/v1",
      "openAiApiKey": "sk-local",
      "openAiModelId": "gemma4:31b"
    },
    "ask": {
      "apiProvider": "openai",
      "openAiBaseUrl": "http://localhost:11434/v1",
      "openAiApiKey": "sk-local",
      "openAiModelId": "qwen3.5-27b:q5"
    },
    "debug": {
      "apiProvider": "openai",
      "openAiBaseUrl": "http://localhost:11434/v1",
      "openAiApiKey": "sk-local",
      "openAiModelId": "deepseek-r1-tools:32b"
    }
  }
}
