{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "qwen3-coder-next-80b:q4",
  "small_model": "qwen3:4b",
  "disabled_providers": [],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/ollama-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "qwen3.6-35b-8k": { "name": "Qwen3.6 35B (8k)" },
        "qwen3.6-35b-32k": { "name": "Qwen3.6 35B (32k)" },
        "qwen3.6-35b-128k": { "name": "Qwen3.6 35B (128k)" },
        "qwen3.6-35b-256k": { "name": "Qwen3.6 35B (256k)" },
        "qwen3-coder-30b-q6-32k": { "name": "Qwen3 Coder 30B Q6 (32k)" },
        "qwen3-coder-30b-q6-128k": { "name": "Qwen3 Coder 30B Q6 (128k)" },
        "qwen3-coder-next-80b-q4": { "name": "Qwen3 Coder Next 80B Q4" },
        "qwen3-coder-next-80b-q4-16k": { "name": "Qwen3 Coder Next 80B Q4 (16k)" },
        "qwen3-coder-next-80b-q4-64k": { "name": "Qwen3 Coder Next 80B Q4 (64k)" },
        "qwen3-coder-next-80b-q4-128k": { "name": "Qwen3 Coder Next 80B Q4 (128k)" },
        "codestral-22b-q8-32k": { "name": "Codestral 22B Q8 (32k)" },
        "qwen2.5-coder-1.5b-q4-32k": { "name": "Qwen2.5 Coder 1.5B Q4 (32k)" },
        "qwen2.5-coder-7b-q4-32k": { "name": "Qwen2.5 Coder 7B Q4 (32k)" },
        "qwen2.5-coder-7b-q8-32k": { "name": "Qwen2.5 Coder 7B Q8 (32k)" },
        "qwen3.5-27b-q8-8k": { "name": "Qwen3.5 27B Q8 (8k)" },
        "qwen3.5-27b-q8-32k": { "name": "Qwen3.5 27B Q8 (32k)" },
        "qwen3.5-27b-q8-128k": { "name": "Qwen3.5 27B Q8 (128k)" },
        "qwen3.5-27b-q8-256k": { "name": "Qwen3.5 27B Q8 (256k)" },
        "qwen3.5-27b-q5-8k": { "name": "Qwen3.5 27B Q5 (8k)" },
        "qwen3.5-27b-q5-32k": { "name": "Qwen3.5 27B Q5 (32k)" },
        "qwen3.5-27b-q5-128k": { "name": "Qwen3.5 27B Q5 (128k)" },
        "qwen3.5-27b-q5-256k": { "name": "Qwen3.5 27B Q5 (256k)" },
        "qwen3-14b-q5-40k": { "name": "Qwen3 14B Q5 (40k)" },
        "qwen3-14b-q8-40k": { "name": "Qwen3 14B Q8 (40k)" },
        "qwen3-32b-q5-32k": { "name": "Qwen3 32B Q5 (32k)" },
        "deepseek-r1-tools-14b-128k": { "name": "DeepSeek R1 Tools 14B (128k)" },
        "deepseek-r1-tools-32b-128k": { "name": "DeepSeek R1 Tools 32B (128k)" },
        "deepseek-r1-q8-128k": { "name": "DeepSeek R1 Q8 (128k)" },
        "qwen3-4b-q8-256k": { "name": "Qwen3 4B Q8 (256k)" },
        "llama3.3-70b": { "name": "Llama 3.3 70B" },
        "gemma4-26b": { "name": "Gemma 4 26B" },
        "glm-4.7-flash-latest": { "name": "GLM 4.7 Flash (latest)" },
        "glm-4.7-flash-q4-198k": { "name": "GLM 4.7 Flash (q4-198k)" },
        "glm-4.7-flash-q8-198k": { "name": "GLM 4.7 Flash (q8-198k)" },
        "qwen3.6-35b-q5-32k": { "name": "Qwen3.6 35B Q5 (32k)" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "env.OPENROUTER_API_KEY"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": { "name": "Claude Sonnet 4.6" },
        "anthropic/claude-opus-4-6": { "name": "Claude Opus 4.6" },
        "moonshot/kimi-k2.6": { "name": "Kimi k2.6 (reasoning)" },
        "google/gemini-2.5-flash": { "name": "Gemini 2.5 Flash" },
        "openai/gpt-4o": { "name": "GPT-4o" }
      }
    }
  },
  "agent": {
    "code": {
      "description": "Primary coding agent — implementation, editing, refactoring, debugging.",
      "model": "qwen3-coder-next-80b:q4-128k",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are the main coding agent. Focus on implementation, refactoring, debugging, and precise code changes. Prefer minimal diffs, preserve existing architecture unless there is a clear reason to change it, and explain tradeoffs briefly.\n\nWhen generating git commit messages: Output ONLY the raw commit message string — no JSON, no markdown, no labels, no wrapping. Format: `type(scope): short description` (≤72 chars, imperative mood, no period). Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build. NEVER write paragraph summaries, numbered breakdowns, or Co-Authored-By trailers."
    },
    "ask": {
      "description": "Q&A agent — answer questions about code, explain logic, provide context.",
      "model": "qwen3-coder-next-80b:q4-128k",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a read-only Q&A agent. Answer questions about the codebase clearly and concisely. Explain logic, trace flows, and provide context. Do not edit files or run commands."
    },
    "debug": {
      "description": "Debugging agent — diagnose errors, trace bugs, suggest fixes.",
      "model": "deepseek-r1-tools-14b-128k",
      "mode": "primary",
      "temperature": 0.3,
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a debugging agent. Diagnose errors, trace bugs through the codebase, and suggest targeted fixes. Read logs, inspect code, and propose minimal, precise solutions. Explain root causes before suggesting changes."
    },
    "plan": {
      "description": "Fast planning agent — next steps, breakdowns, lightweight routing.",
      "model": "qwen2.5-coder-7b-q4-32k",
      "mode": "primary",
      "temperature": 0.25,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a lightweight planning agent. Turn goals into actionable steps, break work into phases, identify blockers, and recommend the next best action. Stay concise, practical, and execution-oriented."
    },
    "think": {
      "description": "Reasoning agent — decision analysis, debugging strategy, tradeoffs.",
      "model": "deepseek-r1-tools-14b-128k",
      "mode": "primary",
      "temperature": 0.3,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a read-only reasoning agent. Provide concise, stepwise analysis of tradeoffs, debugging hypotheses, architectural choices, and evaluation decisions. Do not edit files or run commands."
    },
    "write": {
      "description": "Writing agent — docs, summaries, cover letters, polished prose.",
      "model": "qwen3.6-35b-256k",
      "mode": "primary",
      "temperature": 0.65,
      "permission": {
        "bash": "deny",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a writing-focused agent. Optimize for clarity, tone, structure, and persuasive but concrete language. Produce polished documentation, summaries, and communication."
    },
    "summary": {
      "description": "Commit message and session summary agent.",
      "model": "qwen3-4b-q8-256k",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "bash": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "Generate Conventional Commit messages only. Format: `type(scope): short description` — ≤72 chars, imperative mood, no period. Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build. Never write paragraph summaries, numbered breakdowns, or Co-Authored-By trailers."
    },
    "description": {
      "description": "MR/PR description agent — longer summaries with context.",
      "model": "qwen3-4b-q8-256k",
      "mode": "primary",
      "temperature": 0.3,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "Generate detailed MR/PR descriptions. Include: summary of changes, motivation/context, key files changed, testing notes. Use markdown formatting with headers, bullet points, and code snippets where helpful. Be concise but thorough — aim for 2-4 paragraphs."
    }
  },
  "default_agent": "code",
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "webfetch": "allow"
  }
}
