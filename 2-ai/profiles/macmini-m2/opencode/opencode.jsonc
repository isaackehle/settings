{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM (local)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "sk-local"
      },
      "models": {
        // Primary coding model (~5 GB)
        "qwen2.5-coder-7b": {
          "name": "Qwen2.5 Coder 7B (code, 5 GB)",
          "limit": {
            "context": 8192,
            "output": 2048
          }
        },
        // Autocomplete (~1 GB)
        "qwen2.5-coder-1.5b": {
          "name": "Qwen2.5 Coder 1.5B (autocomplete, 1 GB)"
        },
        // Reasoning + tool calls (~5 GB)
        "deepseek-r1-tools-8b": {
          "name": "DeepSeek R1 8B (reason+tools, 5 GB)",
          "limit": {
            "context": 8192,
            "output": 2048
          }
        },
        // Planning (~3 GB)
        "qwen3-4b-q4": {
          "name": "Qwen3 4B Q4 (plan, fast)",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        }
      }
    }
  },
  "default_agent": "code",
  "model": "litellm/qwen2.5-coder-7b",
  "small_model": "litellm/qwen2.5-coder-1.5b",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "edit": "ask",
    "bash": "ask"
  },
  "agent": {
    "code": {
      "description": "Primary coding agent.",
      "mode": "primary",
      "model": "litellm/qwen2.5-coder-7b",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "ask",
        "bash": "ask"
      },
      "prompt": "You are the main coding agent. Focus on implementation, refactoring, debugging, and precise code changes. Prefer minimal diffs, preserve existing architecture unless there is a clear reason to change it, and explain tradeoffs briefly."
    },
    "think": {
      "description": "Reasoning agent for analysis and debugging strategy.",
      "mode": "primary",
      "model": "litellm/deepseek-r1-tools-8b",
      "temperature": 0.3,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "You are a read-only reasoning agent. Provide concise, stepwise analysis of tradeoffs, debugging hypotheses, architectural choices, interview answers, and evaluation decisions. Do not edit files or run commands."
    },
    "write": {
      "description": "Writing agent for docs, resumes, and prose.",
      "mode": "primary",
      "model": "litellm/qwen2.5-coder-7b",
      "temperature": 0.65,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "ask",
        "bash": "deny"
      },
      "prompt": "You are a writing-focused agent. Optimize for clarity, tone, structure, and persuasive but concrete language. Produce polished resumes, cover letters, technical documentation, summaries, and interview prep materials."
    },
    "research": {
      "description": "Research agent for discovery and structured findings.",
      "mode": "primary",
      "model": "litellm/qwen2.5-coder-7b",
      "temperature": 0.25,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "ask",
        "bash": "deny"
      },
      "prompt": "You are a research agent. Gather evidence, inspect files, compare options, and produce structured findings. Do not execute shell commands.\n\nAt the end of every research session, save your findings to the Obsidian vault at:\n  ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/primary/Research/\n\nName the file using the topic and today's date: `YYYY-MM-DD topic-slug.md`."
    },
    "plan": {
      "description": "Fast planning agent for next steps and breakdowns.",
      "mode": "primary",
      "model": "litellm/qwen3-4b-q4",
      "temperature": 0.25,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "You are a lightweight planning agent. Turn goals into actionable steps, break work into phases, identify blockers, and recommend the next best action. Stay concise, practical, and execution-oriented."
    }
  }
}