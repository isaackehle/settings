# Copy to .env and fill in real values. .env itself must be gitignored —
# only .env.example is committed.

SYNC_PUID=
SYNC_PGID=

# Generate at: Tailscale Admin Console -> Settings -> Keys -> Generate auth key
# Doesn't need to be reusable — it authenticates the sidecar once, then relies
# on the persisted state volume (ts-state) afterward. If that volume is ever
# wiped, you'll need a fresh key here.
TS_AUTHKEY_SYNCTHING=
