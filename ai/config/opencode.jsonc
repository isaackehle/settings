{
  "$schema": "https://opencode.ai/config.json",

  "model": "ollama/qwen3-coder-30b-a3b:q6",
  "small_model": "ollama/qwen3-coder-30b-a3b:q4",

  "agent": {
    "code": {
      "description": "Primary coding agent for implementation, editing, refactoring, and debugging.",
      "mode": "primary",
      "model": "qwen3-coder-30b-a3b:q6",
      "temperature": 0.2,
      "tools": { "home-assistant_*": false, "apple-reminders_*": false }
      // Prompt and permissions live in agents/code.md
    },
    "local": {
      "description": "Fully local agent — no cloud calls, no webfetch. Use for sensitive or offline work.",
      "mode": "primary",
      "model": "qwen3-coder-30b-a3b:q6",
      "temperature": 0.2,
      "tools": { "home-assistant_*": false, "apple-reminders_*": false }
      // Prompt and permissions live in agents/local.md
    },
    "plan": {
      "description": "Fast planning agent for next steps, breakdowns, and lightweight routing.",
      "mode": "primary",
      "model": "ollama/qwen3-coder-30b-a3b:q4",
      "temperature": 0.25,
      "tools": {
        "home-assistant_*": false,
        "apple-reminders_*": false,
        "one-search_*": false,
        "weather_*": false
      }
      // Prompt and permissions live in agents/plan.md
    },
    "research": {
      "description": "Research agent for company research, technical discovery, and structured findings.",
      "mode": "primary",
      "model": "ollama/qwen3.5-27b:q5",
      "temperature": 0.25
      // Prompt and permissions live in agents/research.md
    },
    "think": {
      "description": "Reasoning agent for decision analysis, scoring, debugging strategy, and debriefs.",
      "mode": "primary",
      "model": "ollama/deepseek-r1:32b",
      "temperature": 0.3,
      "tools": { "home-assistant_*": false, "apple-reminders_*": false }
      // Prompt and permissions live in agents/think.md
    },
    "write": {
      "description": "Writing agent for resumes, cover letters, documentation, summaries, and polished prose.",
      "maxTokens": 4096,
      "mode": "primary",
      "model": "qwen3.5-27b:q5",
      "temperature": 0.65,
      "tools": {
        "home-assistant_*": false,
        "apple-reminders_*": false,
        "bash": false,
        "glob": false,
        "grep": false,
        "list": false
      }
      // Prompt and permissions live in agents/write.md
    },
    "build": {
      "description": "Build and test agent — runs build commands, test suites, and CI checks.",
      "mode": "primary",
      "model": "qwen3-coder-30b-a3b:q6",
      "temperature": 0.1
      // Prompt and permissions live in agents/build.md
    },
    "summary": {
      "description": "Commit message and session summary agent.",
      "mode": "primary",
      "model": "qwen3-coder-30b-a3b:q4",
      "temperature": 0.2
      // Prompt and permissions live in agents/summary.md
    },
    "title": {
      "description": "Generate concise PR/MR titles from diffs and commit history.",
      "mode": "primary",
      "model": "qwen3-coder-30b-a3b:q4",
      "temperature": 0.2
      // Prompt and permissions live in agents/title.md
    }
  },

  "default_agent": "code",

  "provider": {
    // ── Tier 1: Local ollama multi-model router (port 10000) ───────────
    "ollama": {
      "name": "Local (ollama)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "codestral-22b": { "name": "Codestral 22B (Apply, FIM)" },
        "deepseek-r1-32b": { "name": "DeepSeek R1 32B (Reasoning)" },
        "laguna-xs.2": { "name": "Laguna XS.2 33B MoE (Alt Coder)" },
        "nomic-embed-text": { "name": "Nomic Embed Text (Embedding)" },
        "qwen2.5-7b": { "name": "Qwen 2.5 7B (General, Multi-Distill)" },
        "qwen2.5-coder-1.5b": { "name": "Qwen 2.5 Coder 1.5B (Autocomplete)" },
        "qwen2.5-coder-7b": { "name": "Qwen 2.5 Coder 7B (Autocomplete)" },
        "qwen3-4b-it": { "name": "Qwen 3 4B (Fast, Planning)" },
        "qwen3-8b-sonnet4.5": {
          "name": "Qwen 3 8B (Claude Sonnet 4.5 Distill)"
        },
        "qwen3-14b-sonnet4.5": {
          "name": "Qwen 3 14B (Claude Sonnet 4.5 Distill)"
        },
        "qwen3-coder-30b-a3b:q6": { "name": "Qwen 3 Coder 30B A3B (Coding, tools ✓)" },
        "qwen3-coder-30b-a3b:q4": { "name": "Qwen 3.5 4B (Fast, Summary)" },
        "qwen3-coder-next-80b:q4:q4": {
          "name": "Qwen 3 Coder Next 80B (Heavy Coding, tools ✓)"
        },
        "qwen3-coder:480b-cloud": { "name": "Qwen 3 Coder 480B (Cloud-routed)" },
        "qwen3.5-27b-gemini3.1": {
          "name": "Qwen 3.5 27B (Gemini 3.1 Distill)"
        },
        "qwen3.5-27b:q5": {
          "name": "Qwen 3.5 27B (Claude Opus 4.6 Distill)"
        },
        "qwen3.5-27b:q5-cloud": { "name": "Qwen 3.5 27B 397B (Cloud-routed)" },
        "qwen3.6-27b:opus-sonnet": {
          "name": "Qwen 3.6 27B (Opus+Sonnet Distill)"
        },
        "qwen3.6-35b:opus4.6": {
          "name": "Qwen 3.6 35B (Claude Opus 4.6 Distill)"
        },
        "gemma-4-e4b": { "name": "Gemma 4 E4M3 Finetune" },
        "gpt-oss-20b": { "name": "GPT-OSS 20B (General)" },
        "lmstudio-community/mistrallite-7b": { "name": "Mistrallite 7B" },
        "ornith-1.0-35b": { "name": "Ornith 1.0 35B" },
        "qwen2.5-3b-instruct": { "name": "Qwen 2.5 3B Instruct" },
        "qwen3-32b-it": { "name": "Qwen 3 32B Instruct" },
        "qwen3.5-9b:opus4.7": { "name": "Qwen 3.5 9B (Opus 4.7 Distill)" },
        "qwen3.6-35b-a3b:opus4.7-128k": {
          "name": "Qwen 3.6 35B (Claude Opus 4.7, 128K, tools ✓)"
        }
      }
    },
    // ── Tier 2: Discovery machine — Tailscale fallback ────────────────────────
    "oollama": {
      "name": "Discovery (ollama)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "codestral-22b": { "name": "Codestral 22B (Apply) [discovery]" },
        "deepseek-r1-32b": {
          "name": "DeepSeek R1 32B (Reasoning) [discovery]"
        },
        "qwen3-4b-it": { "name": "Qwen 3 4B (Fast) [discovery]" },
        "qwen3-coder-30b-a3b:q6": { "name": "Qwen 3 Coder 30B (Coding) [discovery]" },
        "qwen3-coder-next-80b:q4:q4": {
          "name": "Qwen 3 Coder Next 80B (Heavy) [discovery]"
        },
        "qwen3.5-27b:q5": {
          "name": "Qwen 3.5 27B (Opus 4.6) [discovery]"
        },
        "qwen3.6-35b:opus4.7-128k": {
          "name": "Qwen 3.6 35B (Opus 4.7, 128K) [discovery]"
        }
      }
    },
    // ── Tier 3: OpenRouter — cloud fallback ──────────────────────────────────
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter (Cloud)",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "headers": {
          "HTTP-Referer": "https://localhost",
          "X-Title": "OpenCode CLI"
        }
      },
      "models": {
        "anthropic/claude-haiku-4-5": {
          "name": "Claude Haiku 4.5 (Fast, Cheap)"
        },
        "anthropic/claude-haiku-4-5:nitro": {
          "name": "Claude Haiku 4.5 (Nitro)"
        },
        "anthropic/claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Balanced)"
        },
        "anthropic/claude-sonnet-4-6:exacto": {
          "name": "Claude Sonnet 4.6 (Exacto, Tool-Optimized)"
        },
        "anthropic/claude-opus-4-6": {
          "name": "Claude Opus 4.6 (Best Quality)"
        },
        "deepseek/deepseek-r1-tool-calling-32b": {
          "name": "DeepSeek R1 32B Tools (Cloud)"
        },
        "google/gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Fast, Vision)"
        },
        "google/gemini-2.5-flash:online": {
          "name": "Gemini 2.5 Flash (Online, Web Search)"
        },
        "google/gemini-2.5-pro": { "name": "Gemini 2.5 Pro (Multimodal)" },
        "mistralai/codestral": { "name": "Codestral (FIM, Cloud)" },
        "moonshot/kimi-k2.6": { "name": "Kimi K2.6 (Long Context)" },
        "openai/gpt-4o": { "name": "GPT-4o (Vision, General)" },
        "openai/o3": { "name": "o3 (Heavy Reasoning)" },
        "openrouter/free": { "name": "Free Models Router" },
        "perplexity/sonar-pro": { "name": "Sonar Pro (Web Search)" },
        "x-ai/grok-3": { "name": "Grok 3 (General)" },
        "x-ai/grok-3-mini": { "name": "Grok 3 Mini (Fast, Cheap)" }
      }
    }
  },

  "server": {
    "port": 4096,
    "mdns": true
  },

  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "sudo *": "ask"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "webfetch": "allow",
    "external_directory": "ask"
  },

  "mcp": {
    "apple-reminders": {
      "type": "local",
      "command": ["npx", "-y", "mcp-server-apple-events"],
      "enabled": true
    },
    "home-assistant": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-proxy",
        "--transport",
        "streamablehttp",
        "https://homeassistant.tail303fda.ts.net:9584/***REMOVED-HA-MCP-PATH-SECRET***"
      ],
      "enabled": true
    },
    "weather": {
      "type": "local",
      "command": ["npx", "-y", "@dangahagan/weather-mcp@latest"],
      "enabled": true
    },
    "one-search": {
      "type": "local",
      "command": ["npx", "-y", "one-search-mcp"],
      "enabled": true,
      "env": { "SEARCH_PROVIDER": "duckduckgo" }
    }
  },

  "experimental": { "mcp_timeout": 8000 },
  "instructions": [],
  "plugin": ["opencode-openai-codex-auth@latest"]
}
