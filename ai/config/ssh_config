# ~/.ssh/config — fleet SSH configuration
# Copy to ~/.ssh/config on each machine:
#   cp ~/code/isaackehle/settings/_config/ssh_config ~/.ssh/config
#   chmod 600 ~/.ssh/config
#
# First-match-wins: Tailscale is tried first, local network is fallback.

# ── Tailscale (first match wins) ──────────────────────────────────────────────
Host dx1 discovery ds9 voyager
    HostName %h.tail303fda.ts.net
    User isaac
    IdentityFile ~/.ssh/id_ed25519
    AddKeysToAgent yes
    UseKeychain yes
    SendEnv TERM
    RequestTTY yes
    ServerAliveInterval 30
    ServerAliveCountMax 3

# ── Local network fallback ─────────────────────────────────────────────────────
Host dx1.local discovery.local ds9.local enterprise.local
    HostName %h
    User isaac
    IdentityFile ~/.ssh/id_ed25519
    AddKeysToAgent yes
    UseKeychain yes
    SetEnv TERM=xterm-256color
    RequestTTY yes
    ServerAliveInterval 30
    ServerAliveCountMax 3
