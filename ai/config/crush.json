{
    "$schema": "https://charm.land/crush.json",
    "models": {
        "fast": {
            "model": "qwen3:4b",
            "provider": "ollama",
            "max_tokens": 4096
        },
        "large": {
            "model": "qwen3-coder-30b-a3b:q6",
            "provider": "ollama",
            "max_tokens": 8192
        },
        "reasoning": {
            "model": "qwen3.6-35b:opus4.7-128k",
            "provider": "ollama",
            "max_tokens": 8192
        },
        "writing": {
            "model": "qwen3.5-27b:q5",
            "provider": "ollama",
            "max_tokens": 8192
        }
    },
    "providers": {
        "ollama": {
            "name": "Ollama (Local)",
            "type": "openai-compat",
            "base_url": "http://127.0.0.1:11434/v1",
            "api_key": "sk-local"
        },
        "openrouter": {
            "name": "OpenRouter (Cloud)",
            "type": "openai-compat",
            "base_url": "https://openrouter.ai/api/v1",
            "api_key": "${OPENROUTER_API_KEY:?}"
        }
    },
    "mcp": {
        "amazon": {
            "type": "stdio",
            "command": "/Users/isaac/.local/share/fnm/node-versions/v24.15.0/installation/bin/node",
            "args": [
                "/Users/isaac/code/mcp-server-amazon/build/index.js"
            ]
        },
        "apple-reminders": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "mcp-server-apple-events"
            ]
        },
        "duckduckgo": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@aiprintmoney-arc/mcp-server-duckduckgo"
            ]
        },
        "home-assistant": {
            "type": "http",
            "url": "https://kehle.duckdns.org:8123/api/mcp",
            "headers": {
                "Authorization": "Bearer ***REMOVED-HA-TOKEN***"
            }
        },
        "one-search": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "one-search-mcp"
            ],
            "env": {
                "SEARCH_PROVIDER": "duckduckgo"
            }
        },
        "weather": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@dangahagan/weather-mcp@latest"
            ]
        }
    }
}