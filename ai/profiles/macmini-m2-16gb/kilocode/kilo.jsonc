{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "qwen2.5-coder:7b",
  "small_model": "qwen3:4b",
  "disabled_providers": [],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "qwen3:14b": { "name": "Heavy / General — 14B" },
        "qwen3:14b-128k": { "name": "Heavy / General — 14B (+long)" },
        "qwen2.5-coder:7b": { "name": "Coder — 7B" },
        "deepseek-r1:7b": { "name": "Reasoning — DeepSeek R1 7B" },
        "qwen3:4b": { "name": "Fast / Plan — 4B" },
        "nomic-embed-text": { "name": "Embed" },
        "qwen3.5:4b": { "name": "Qwen3.5 — 4B" },
        "qwen3-8b:sonnet4.5": { "name": "Claude Sonnet 4.5 distill — 8B" },
        "qwen2.5-7b:multi": { "name": "Multi-distill Claude+Gemini+GPT — 7B" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "env.OPENROUTER_API_KEY"
      },
      "models": {
        "anthropic/claude-opus-4-6":   { "name": "Claude Opus 4.6 (CLD)" },
        "anthropic/claude-sonnet-4-6": { "name": "Claude Sonnet 4.6 (CLD)" },
        "google/gemini-2.5-flash":     { "name": "Gemini 2.5 Flash (CLD)" },
        "moonshot/kimi-k2.6":          { "name": "Kimi K2.6 (REAS, CLD)" },
        "openai/gpt-4o":               { "name": "GPT-4o (CLD)" }
      }
    }
  },
  "permission": { "bash": "ask", "edit": "ask", "glob": "allow", "grep": "allow",
                  "list": "allow", "read": "allow", "webfetch": "allow" }
}
