{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "ollama/qwen2.5-coder:7b",
  "small_model": "ollama/qwen3.5:4b",
  "disabled_providers": [],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "deepseek-r1:7b": { "name": "DeepSeek R1 7B (Reasoning)" },
        "nomic-embed-text": { "name": "Nomic Embed Text (Embedding)" },
        "qwen2.5-7b:multi": { "name": "Qwen 2.5 7B Multi (Claude+Gemini+GPT Distill)" },
        "qwen2.5-coder:7b": { "name": "Qwen 2.5 Coder 7B (Coding)" },
        "qwen3-8b:sonnet4.5": { "name": "Qwen3 8B (Claude Sonnet 4.5 Distill)" },
        "qwen3.5:4b": { "name": "Qwen 3.5 4B (Planning, Writing)" },
        "qwen3.5:4b-128k": { "name": "Qwen 3.5 4B (Planning, Writing, 128K)" },
        "qwen3:14b": { "name": "Qwen3 14B (General)" },
        "qwen3:14b-128k": { "name": "Qwen3 14B (General, 128K)" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "env.OPENROUTER_API_KEY"
      },
      "models": {
        "anthropic/claude-opus-4-6": { "name": "Claude Opus 4.6 (Heavy Reasoning, Best Quality)" },
        "anthropic/claude-sonnet-4-6": { "name": "Claude Sonnet 4.6 (Balanced All-Rounder)" },
        "google/gemini-2.5-flash": { "name": "Gemini 2.5 Flash (Fast, Vision, Long Context)" },
        "moonshot/kimi-k2.6": { "name": "Kimi K2.6 (Deep Reasoning, Long Context)" },
        "openai/gpt-4o": { "name": "GPT-4o (General, Vision, Multimodal)" }
      }
    }
  },
  "agent": {
    "code": {
      "description": "Primary coding agent — implementation, editing, refactoring, debugging.",
      "model": "ollama/qwen2.5-coder:7b",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "*": "ask",
          "rm -rf *": "deny",
          "sudo *": "deny",
          "git *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "diff *": "allow",
          "echo *": "allow",
          "printf *": "allow",
          "mkdir *": "allow",
          "touch *": "allow",
          "cp *": "allow",
          "mv *": "allow",
          "chmod *": "allow",
          "python *": "allow",
          "node *": "allow",
          "npm *": "allow",
          "pip *": "allow",
          "uv *": "allow"
        },
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are the main coding agent. Focus on implementation, refactoring, debugging, and precise code changes. Prefer minimal diffs, preserve existing architecture unless there is a clear reason to change it, and explain tradeoffs briefly.\n\nWhen generating git commit messages: Output ONLY the raw commit message string — no JSON, no markdown, no labels, no wrapping. Format: `type(scope): short description` (≤72 chars, imperative mood, no period). Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build. NEVER write paragraph summaries, numbered breakdowns, or Co-Authored-By trailers."
    },
    "ask": {
      "description": "Q&A agent — answer questions about code, explain logic, provide context.",
      "model": "ollama/qwen2.5-coder:7b",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a read-only Q&A agent. Answer questions about the codebase clearly and concisely. Explain logic, trace flows, and provide context. Do not edit files or run commands."
    },
    "debug": {
      "description": "Debugging agent — diagnose errors, trace bugs, suggest fixes.",
      "model": "ollama/deepseek-r1:7b",
      "mode": "primary",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "*": "ask",
          "rm -rf *": "deny",
          "sudo *": "deny",
          "git *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "diff *": "allow",
          "echo *": "allow",
          "printf *": "allow",
          "python *": "allow",
          "node *": "allow"
        },
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a debugging agent. Diagnose errors, trace bugs through the codebase, and suggest targeted fixes. Read logs, inspect code, and propose minimal, precise solutions. Explain root causes before suggesting changes."
    },
    "plan": {
      "description": "Fast planning agent — next steps, breakdowns, lightweight routing.",
      "model": "ollama/qwen3.5:4b",
      "mode": "primary",
      "temperature": 0.25,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a lightweight planning agent. Turn goals into actionable steps, break work into phases, identify blockers, and recommend the next best action. Stay concise, practical, and execution-oriented."
    },
    "think": {
      "description": "Reasoning agent — decision analysis, debugging strategy, tradeoffs.",
      "model": "ollama/deepseek-r1:7b",
      "mode": "primary",
      "temperature": 0.3,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a read-only reasoning agent. Provide concise, stepwise analysis of tradeoffs, debugging hypotheses, architectural choices, and evaluation decisions. Do not edit files or run commands."
    },
    "write": {
      "description": "Writing agent — docs, summaries, cover letters, polished prose.",
      "model": "ollama/qwen3:14b",
      "mode": "primary",
      "temperature": 0.65,
      "permission": {
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "echo *": "allow",
          "printf *": "allow"
        },
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "You are a writing-focused agent. Optimize for clarity, tone, structure, and persuasive but concrete language. Produce polished documentation, summaries, and communication."
    },
    "summary": {
      "description": "Commit message and session summary agent.",
      "model": "ollama/qwen3.5:4b",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "*": "deny",
          "git diff *": "allow",
          "git log *": "allow",
          "git status": "allow",
          "git diff --stat": "allow",
          "git diff --cached": "allow",
          "git diff HEAD": "allow",
          "git log --oneline -10": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "echo *": "allow",
          "printf *": "allow"
        },
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "Generate Conventional Commit messages only. Format: `type(scope): short description` — ≤72 chars, imperative mood, no period. Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build. Never write paragraph summaries, numbered breakdowns, or Co-Authored-By trailers."
    },
    "description": {
      "description": "MR/PR description agent — longer summaries with context.",
      "model": "ollama/qwen3:14b",
      "mode": "primary",
      "temperature": 0.3,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow"
      },
      "prompt": "Generate detailed MR/PR descriptions. Include: summary of changes, motivation/context, key files changed, testing notes. Use markdown formatting with headers, bullet points, and code snippets where helpful. Be concise but thorough — aim for 2-4 paragraphs."
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "curl *": "allow",
      "wget *": "allow",
      "git *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "diff *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "chmod *": "allow",
      "brew *": "allow",
      "ollama *": "allow",
      "python *": "allow",
      "node *": "allow",
      "npm *": "allow",
      "pip *": "allow",
      "uv *": "allow"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "webfetch": "allow"
  }
}
