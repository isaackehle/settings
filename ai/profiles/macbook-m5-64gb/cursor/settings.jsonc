{
  // Cursor (cursor.sh) — VS Code-compatible settings snippet
  // MERGE INTO: ~/Library/Application Support/Cursor/User/settings.json
  //
  // To use Ollama directly in Cursor:
  //   1. Open Cursor Settings (Cmd+Shift+J) → Models
  //   2. Under "Ollama", set base URL to http://localhost:11434
  //   3. Add custom models (click + next to model list):
  //        qwen3-coder-30b-a3b:q6     (primary coding)
  //        qwen3.6-35b:opus4.7-128k   (architect, Opus 4.6 distill, 109 t/s, 128K ctx)
  //        laguna-xs.2                (alt coder, 68% SWE-bench)
  //        deepseek-r1-tools:32b      (reasoning + tools)
  //        qwen3.5-27b:q4             (writing/research)
  //        qwen3:4b                   (planning/fast)
  //   4. Set default model to: qwen3-coder-30b-a3b:q6
  //
  // Cloud fallback:
  //   Use Cursor's native claude-sonnet-4-6 or set OpenRouter key
  //   and model kimi-k2.6

  "cursor.general.enableShadowWorkspace": false,
  "cursor.chat.smoothStreaming": true,
  "cursor.cpp.disabledLanguages": [],

  // Privacy: disable telemetry of prompts to Cursor servers
  "cursor.privacy.telemetryLevel": "off"

  // Cursor Rules (equivalent of CLAUDE.md) — set per-project in .cursor/rules/
  // Global rules can be set in Settings → Rules for AI
}
