{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "ollama/qwen3-coder-30b-a3b:q6",
  "small_model": "ollama/qwen3.5:4b",
  "disabled_providers": [],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "codestral:22b": { "name": "Codestral 22B — Diff, Apply" },
        "deepseek-r1:32b": { "name": "DeepSeek R1 32B — Reasoning" },
        "deepseek-r1:32b-128k": { "name": "DeepSeek R1 32B 128K — Reasoning" },
        "deepseek-r1-tools:32b": { "name": "DeepSeek R1 Tools 32B — Reasoning, Tools" },
        "deepseek-r1-tools:32b-128k": { "name": "DeepSeek R1 Tools 32B 128K — Reasoning, Tools" },
        "nomic-embed-text": { "name": "Nomic Embed Text — Embedding" },
        "qwen2.5-7b:multi": { "name": "Qwen 2.5 7B Multi — Claude+Gemini+GPT distill" },
        "qwen2.5-coder:1.5b": { "name": "Qwen 2.5 Coder 1.5B — Autocomplete" },
        "qwen2.5-coder:7b": { "name": "Qwen 2.5 Coder 7B — Autocomplete" },
        "qwen3-14b:sonnet4.5": { "name": "Qwen3 14B — Claude Sonnet 4.5 distill" },
        "qwen3-8b:sonnet4.5": { "name": "Qwen3 8B — Claude Sonnet 4.5 distill" },
        "qwen3-coder-30b-a3b:q6": { "name": "Qwen3 Coder 30B A3B — Coding" },
        "qwen3-coder-30b-a3b:q6-128k": { "name": "Qwen3 Coder 30B A3B 128K — Coding" },
        "qwen3.5-27b:gemini3.1": { "name": "Qwen 3.5 27B — Gemini 3.1 distill" },
        "qwen3.5-27b:q4": { "name": "Qwen 3.5 27B — Writing, Claude Opus distill" },
        "qwen3.5-27b:q4-128k": { "name": "Qwen 3.5 27B 128K — Writing" },
        "qwen3.5:4b": { "name": "Qwen 3.5 4B — Planning, Writing" },
        "qwen3.5:4b-128k": { "name": "Qwen 3.5 4B 128K — Planning, Writing" },
        "qwen3.6-27b:opus-sonnet": { "name": "Qwen 3.6 27B — Claude Opus+Sonnet distill" }
      }
    },
    // ── llama.cpp — native tool calling via GGUF Jinja2 template ─────────────
    "llamacpp-coder": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp — Coder 30B",
      "options": { "baseURL": "http://localhost:8013/v1", "apiKey": "sk-local" },
      "models": {
        "qwen3-coder-30b-a3b:q6": { "name": "Qwen3 Coder 30B A3B — Coding, llama.cpp" }
      }
    },
    "llamacpp-embedding": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp — Embedding",
      "options": { "baseURL": "http://localhost:8016/v1", "apiKey": "sk-local" },
      "models": {
        "nomic-embed-text": { "name": "Nomic Embed Text — Embedding, llama.cpp" }
      }
    },
    "llamacpp-fast": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp — Fast 4B",
      "options": { "baseURL": "http://localhost:8011/v1", "apiKey": "sk-local" },
      "models": {
        "qwen3:4b": { "name": "Qwen3 4B — Planning, llama.cpp" }
      }
    },
    "llamacpp-general": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp — General 27B",
      "options": { "baseURL": "http://localhost:8012/v1", "apiKey": "sk-local" },
      "models": {
        "qwen3.5-27b:q4": { "name": "Qwen 3.5 27B — Writing, Claude Opus distill, llama.cpp" }
      }
    },
    "llamacpp-heavy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp — Heavy 35B",
      "options": { "baseURL": "http://localhost:8014/v1", "apiKey": "sk-local" },
      "models": {
        "qwen3.6-35b:opus4.6": { "name": "Qwen 3.6 35B — Heavy, Claude Opus distill, llama.cpp" }
      }
    },
    "llamacpp-reasoning": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp — Reasoning 32B",
      "options": { "baseURL": "http://localhost:8015/v1", "apiKey": "sk-local" },
      "models": {
        "deepseek-r1:32b": { "name": "DeepSeek R1 32B — Reasoning, llama.cpp" }
      }
    },
    "llamacpp-summary": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp — Summary 4B",
      "options": { "baseURL": "http://localhost:8017/v1", "apiKey": "sk-local" },
      "models": {
        "qwen3.5:4b": { "name": "Qwen 3.5 4B — Planning, Writing, llama.cpp" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "env.OPENROUTER_API_KEY"
      },
      "models": {
        "anthropic/claude-opus-4-6": { "name": "Claude Opus 4.6 — Cloud" },
        "anthropic/claude-sonnet-4-6": { "name": "Claude Sonnet 4.6 — Cloud" },
        "google/gemini-2.5-flash": { "name": "Gemini 2.5 Flash — Cloud" },
        "moonshot/kimi-k2.6": { "name": "Kimi K2.6 — Reasoning, Cloud" },
        "openai/gpt-4o": { "name": "GPT-4o — Cloud" }
      }
    }
  },
  "agent": {
    "code": {
      "description": "Primary coding agent — implementation, editing, refactoring, debugging.",
      "model": "ollama/qwen3-coder-30b-a3b:q6-32k",
      "mode": "primary",
      "temperature": 0.2
      // Prompt and permissions live in ~/.kilo/agents/code.md
    },
    "ask": {
      "description": "Q&A agent — answer questions about code, explain logic, provide context.",
      "model": "ollama/qwen3-coder-30b-a3b:q6-32k",
      "mode": "primary",
      "temperature": 0.2
      // Prompt and permissions live in ~/.kilo/agents/ask.md
    },
    "debug": {
      "description": "Debugging agent — diagnose errors, trace bugs, suggest fixes.",
      "model": "ollama/deepseek-r1:32b-128k",
      "mode": "primary",
      "temperature": 0.3
      // Prompt and permissions live in ~/.kilo/agents/debug.md
    },
    "plan": {
      "description": "Fast planning agent — next steps, breakdowns, lightweight routing.",
      "model": "ollama/qwen3.5:4b",
      "mode": "primary",
      "temperature": 0.25
      // Prompt and permissions live in ~/.kilo/agents/plan.md
    },
    "think": {
      "description": "Reasoning agent — decision analysis, debugging strategy, tradeoffs.",
      "model": "ollama/deepseek-r1:32b-128k",
      "mode": "primary",
      "temperature": 0.3
      // Prompt and permissions live in ~/.kilo/agents/think.md
    },
    "write": {
      "description": "Writing agent — docs, summaries, cover letters, polished prose.",
      "model": "ollama/qwen3.5-27b:q4-128k",
      "mode": "primary",
      "temperature": 0.65
      // Prompt and permissions live in ~/.kilo/agents/write.md
    },
    "summary": {
      "description": "Commit message and session summary agent.",
      "model": "ollama/qwen3.5:4b",
      "mode": "primary",
      "temperature": 0.2
      // Prompt and permissions live in ~/.kilo/agents/summary.md
    },
    "description": {
      "description": "MR/PR description agent — longer summaries with context.",
      "model": "ollama/qwen3.5-27b:q4",
      "mode": "primary",
      "temperature": 0.3
      // Prompt and permissions live in ~/.kilo/agents/description.md
    },
    "architect": {
      "description": "Stress-test technical designs and produce implementation-ready plans.",
      "model": "ollama/deepseek-r1:32b-128k",
      "mode": "primary",
      "temperature": 0.3
      // Prompt and permissions live in ~/.kilo/agents/architect.md
    },
    "code-reviewer": {
      "description": "Senior software engineer conducting thorough code reviews.",
      "model": "ollama/qwen3-coder-30b-a3b:q6-32k",
      "mode": "primary",
      "temperature": 0.2
      // Prompt and permissions live in ~/.kilo/agents/code-reviewer.md
    },
    "test-engineer": {
      "description": "QA engineer and testing specialist.",
      "model": "ollama/qwen3-coder-30b-a3b:q6-32k",
      "mode": "primary",
      "temperature": 0.2
      // Prompt and permissions live in ~/.kilo/agents/test-engineer.md
    }
  },
  "mcp": {
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git"]
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "env.AGENT_GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    }
  },
  "default_agent": "code",
  "permission": {
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "curl *": "allow",
      "wget *": "allow",
      "git *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "diff *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "chmod *": "allow",
      "brew *": "allow",
      "ollama *": "allow",
      "python *": "allow",
      "node *": "allow",
      "npm *": "allow",
      "pip *": "allow",
      "uv *": "allow"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "webfetch": "allow"
  }
}
