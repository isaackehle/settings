{
  // Kilo Code (kilohealth.kilo-code) — VS Code settings snippet
  // MERGE INTO: ~/Library/Application Support/Code/User/settings.json
  //
  // API config is set via the Kilo Code sidebar → API Provider: OpenAI Compatible
  //   Base URL  → http://localhost:11434/v1
  //   API Key   → sk-local
  //   Model     → qwen3-coder-next-80b:q4
  //
  // Cloud fallback:
  //   Provider  → OpenRouter
  //   API Key   → $OPENROUTER_API_KEY
  //   Model     → moonshot/kimi-k2.6
  //
  // Note: Kilo Code uses the same Cline-based architecture as Roo Code.
  //       All Ollama model names (colon format) are valid here.

  "kilocode.preferredLanguage": "English",
  "kilocode.alwaysAllowReadOnly": true,
  "kilocode.alwaysAllowReadOnlyOutsideWorkspace": false,
  "kilocode.alwaysAllowWrite": false,
  "kilocode.alwaysAllowExecute": false
}
