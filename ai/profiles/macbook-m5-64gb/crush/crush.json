{
    "$schema": "https://charm.land/crush.json",
    "models": {
        "large": {
            "model": "qwen3-coder-30b",
            "provider": "llama-gp-router",
            "max_tokens": 8192
        },
        "fast": {
            "model": "qwen3:4b",
            "provider": "llama-gp-router",
            "max_tokens": 4096
        },
        "writing": {
            "model": "qwen3.5-27b",
            "provider": "llama-heavy",
            "max_tokens": 8192
        }
    },
    "providers": {
        "llama-gp-router": {
            "name": "llama.cpp router (local)",
            "type": "openai-compat",
            "base_url": "http://localhost:10000/v1",
            "api_key": "sk-local"
        },
        "llama-discovery": {
            "name": "llama.cpp router (discovery)",
            "type": "openai-compat",
            "base_url": "http://100.64.0.1:10000/v1",
            "api_key": "sk-local"
        },
        "openrouter": {
            "name": "OpenRouter (cloud)",
            "type": "openai-compat",
            "base_url": "https://openrouter.ai/api/v1",
            "api_key": "${OPENROUTER_API_KEY:?}"
        }
    },
    "mcp": {}
}