{
  "$schema": "https://opencode.ai/config.json",
  "//": "Models reference: ~/.models | Multi-tier fallback: local -> discovery -> openrouter",
  "default_agent": "code",
  "model": "qwen3-coder-30b",
  "small_model": "qwen3:4b",
  "providers": {
    "llama-gp-router": {
      "name": "llama.cpp router (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {"baseURL": "http://localhost:10000/v1", "apiKey": "sk-local"}
    },
    "llama-discovery": {
      "name": "llama.cpp router (discovery)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {"baseURL": "http://100.64.0.1:10000/v1", "apiKey": "sk-local"}
    },
    "openrouter": {
      "name": "OpenRouter",
      "npm": "@ai-sdk/openai-compatible",
      "options": {"baseURL": "https://openrouter.ai/api/v1", "apiKey": "{env:OPENROUTER_API_KEY}"}
    }
  },
  "mcp": {
    "apple-reminders": {"type": "local", "command": ["npx", "-y", "mcp-server-apple-events"], "enabled": true},
    "home-assistant": {"type": "local", "command": ["uvx", "ha-mcp@latest"], "enabled": true, "env": {"HOMEASSISTANT_URL": "https://kehle.duckdns.org:8123", "HOMEASSISTANT_TOKEN": "${HOMEASSISTANT_TOKEN}"}},
    "weather": {"type": "local", "command": ["npx", "-y", "@dangahagan/weather-mcp@latest"], "enabled": true},
    "one-search": {"type": "local", "command": ["npx", "-y", "one-search-mcp"], "enabled": true, "env": {"SEARCH_PROVIDER": "duckduckgo"}}
  }
}
