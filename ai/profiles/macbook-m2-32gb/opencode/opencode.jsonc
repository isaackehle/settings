{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "code": {
      "description": "Primary coding agent for implementation, editing, refactoring, and debugging.",
      "maxTokens": 16000,
      "mode": "primary",
      "model": "ollama/qwen3-coder-30b-a3b:q5",
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow",
        "external_directory": "ask"
      },
      "prompt": "You are the main coding agent. Focus on implementation, refactoring, debugging, and precise code changes. Prefer minimal diffs, preserve existing architecture unless there is a clear reason to change it, and explain tradeoffs briefly.",
      "temperature": 0.2
    },
    "local": {
      "description": "Fully local agent — no cloud calls, no webfetch. Use for sensitive or offline work.",
      "maxTokens": 8000,
      "mode": "primary",
      "model": "ollama/qwen3-coder-30b-a3b:q5",
      "permission": {
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "deny",
        "external_directory": "ask"
      },
      "prompt": "You are a fully local coding agent with no internet access. Work only with files and context provided. Be explicit when you need information you cannot access.",
      "temperature": 0.2
    },
    "plan": {
      "description": "Fast planning agent for next steps, breakdowns, and lightweight routing.",
      "maxTokens": 1500,
      "mode": "primary",
      "model": "ollama/qwen3:4b",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow",
        "external_directory": "ask"
      },
      "prompt": "You are a lightweight planning agent. Turn goals into actionable steps, break work into phases, identify blockers, and recommend the next best action. Stay concise, practical, and execution-oriented.",
      "temperature": 0.25
    },
    "research": {
      "description": "Research agent for company research, technical discovery, and structured findings.",
      "mode": "primary",
      "model": "ollama/qwen3-coder-30b-a3b:q5",
      "permission": {
        "bash": "deny",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow",
        "external_directory": "ask"
      },
      "prompt": "You are a research agent. Gather evidence, inspect files, compare options, and produce structured findings. Do not execute shell commands.\n\nAt the end of every research session, save your findings to the Obsidian vault at:\n  ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/primary/Research/\n\nName the file using the topic and today's date: `YYYY-MM-DD topic-slug.md`.\n\nStructure the file as:\n# <Topic>\n_Date: YYYY-MM-DD_\n\n## Summary\n<2-4 sentences>\n\n## Findings\n<bullet points, organized by sub-topic>\n\n## Open Questions\n<what still needs investigation>\n\n## Next Steps\n<concrete recommended actions>\n\nIf the user explicitly says not to save, skip writing the file.",
      "temperature": 0.25
    },
    "think": {
      "description": "Reasoning agent for decision analysis, scoring, debugging strategy, and debriefs.",
      "mode": "primary",
      "model": "ollama/deepseek-r1:7b",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow",
        "external_directory": "ask"
      },
      "prompt": "You are a read-only reasoning agent. Provide concise, stepwise analysis of tradeoffs, debugging hypotheses, architectural choices, interview answers, and evaluation decisions. Do not edit files or run commands. Produce clear structured reasoning, alternatives, and recommendations.",
      "temperature": 0.3
    },
    "write": {
      "description": "Writing agent for resumes, cover letters, documentation, summaries, and polished prose.",
      "mode": "primary",
      "model": "ollama/qwen3.5-27b:q4",
      "permission": {
        "bash": "deny",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "allow",
        "external_directory": "ask"
      },
      "prompt": "You are a writing-focused agent. Optimize for clarity, tone, structure, and persuasive but concrete language. Produce polished resumes, cover letters, technical documentation, summaries, and interview prep materials. Avoid unnecessary verbosity and keep claims specific.",
      "temperature": 0.65
    }
  },
  "default_agent": "code",
  "model": "ollama/qwen3-coder-30b-a3b:q5",
  "small_model": "ollama/qwen3:4b",
  // 2. Server Configuration (Does NOT store password)
  "server": {
    "port": 4096,
    "mdns": true
  },

  // 3. Permissions (Critical for avoiding silent hangs)
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "ask", // Granular deny rules
      "sudo *": "ask"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "webfetch": "allow",
    "external_directory": "ask"
  },
  "provider": {
    "ollama": {
      "name": "Ollama (Local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder-30b-a3b:q5": { "name": "Coder — 30B" },
        "qwen3-coder-30b-a3b:q5-128k": { "name": "Coder — 30B (+long)" },
        "qwen3.5-27b:q4": { "name": "Writing / General — 27B (Claude Opus distill)" },
        "qwen3.5-27b:q4-128k": { "name": "Writing / General — 27B (+long)" },
        "qwen3:14b": { "name": "Heavy — 14B" },
        "deepseek-r1:7b": { "name": "Reasoning — DeepSeek R1 7B" },
        "qwen3:4b": { "name": "Fast / Plan — 4B" },
        "nomic-embed-text": { "name": "Embed" },
        "qwen3.5-9b:opus4.6": { "name": "Claude Opus 4.6 distill — 9B" },
        "qwen3.5-9b:gemini3.1": { "name": "Gemini 3.1 distill — 9B" },
        "qwen3-8b:sonnet4.5": { "name": "Claude Sonnet 4.5 distill — 8B" },
        "qwen3-14b:sonnet4.5": { "name": "Claude Sonnet 4.5 distill — 14B" },
        "qwen2.5-7b:multi": { "name": "Multi-distill Claude+Gemini+GPT — 7B" },
        "qwen3.5:4b": { "name": "Qwen3.5 — 4B" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}",
        // Optional: Required by some OpenRouter features for leaderboards
        "headers": {
          "HTTP-Referer": "https://localhost",
          "X-Title": "OpenCode CLI"
        }
      },
      "models": {
        "anthropic/claude-haiku-4-5": { "name": "Claude Haiku 4.5 — Fast, cheap, lightweight" },
        "anthropic/claude-opus-4-6": { "name": "Claude Opus 4.6 — Heavy reasoning, best quality" },
        "anthropic/claude-sonnet-4-6": { "name": "Claude Sonnet 4.6 — Balanced all-rounder" },
        "deepseek/deepseek-r1-tool-calling-32b": { "name": "DeepSeek R1 32B Tools — Reasoning + tool calling" },
        "google/gemini-2.5-flash": { "name": "Gemini 2.5 Flash — Fast, vision, long context" },
        "google/gemini-2.5-pro": { "name": "Gemini 2.5 Pro — Deep reasoning, multimodal" },
        "mistralai/codestral": { "name": "Codestral — Code generation, fill-in-middle" },
        "mistralai/mistral-large": { "name": "Mistral Large — Strong general purpose" },
        "moonshot/kimi-k2.6": { "name": "Kimi K2.6 — Deep reasoning, long context" },
        "openai/gpt-4o": { "name": "GPT-4o — General, vision, multimodal" },
        "openai/o3": { "name": "OpenAI o3 — Heavy reasoning, STEM" },
        "perplexity/sonar-pro": { "name": "Sonar Pro — Web search + chat" },
        "qwen/qwen3-8b": { "name": "Qwen3 8B — Fast planning, cheap" },
        "qwen/qwen3-coder-next-80b": { "name": "Qwen3 Coder Next 80B — Heavy coding" },
        "thudm/glm-5.1": { "name": "GLM 5.1 — General purpose" },
        "x-ai/grok-3": { "name": "Grok 3 — General, real-time data" },
        "x-ai/grok-3-mini": { "name": "Grok 3 Mini — Fast, cheap" }
      }
    }
  },

  // 5. Instructions & Plugins
  "instructions": ["CONTRIBUTING.md", "docs/*.md"],
  "plugin": ["opencode-openai-codex-auth@latest"]
}
