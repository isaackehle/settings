# Link Bot — configuration
# Copy this to config.local.env and fill in your values.

# Required: Telegram bot token from @BotFather
BOT_TOKEN=""

# Required: Your Telegram user ID (bot only responds to you)
# Get it from @userinfobot
ALLOWED_USER_ID=""

# Ollama endpoint (Mac mini runs this locally)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="qwen3:14b"

# Optional: OpenRouter API key for cloud fallback
# Leave blank to use Ollama only
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"

# Output directory for saved link summaries
OUTPUT_DIR="${HOME}/code/isaackehle/settings/saved-links"
