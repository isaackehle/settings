# Inbox Bot — configuration reference
#
# Set these where they belong:
#
#   ~/.env.local            Secrets (not in repo)
#   ~/.profile.d/_inbox     Destinations (deployed from config/profile.d/)
#
# ── Required: ~/.env.local ─────────────────────────────────────────────────
#
#   export BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"
#   export ALLOWED_USER_ID="123456789"
#
# ── Optional: ~/.env.local ─────────────────────────────────────────────────
#
#   export OPENROUTER_API_KEY="sk-or-..."
#
# ── Destinations: ~/.profile.d/_inbox (or config/profile.d/_inbox) ────────
#
#   export DESTINATIONS='{
#     "incoming": "~/vault/incoming",
#     "links": "~/code/isaackehle/settings/saved-links",
#     "notes": "~/vault/incoming"
#   }'
#
# ── Launchd: com.user.link-bot.plist ───────────────────────────────────────
# Uses literal paths (launchd doesn't source shell config). Edit the plist
# directly if you change destinations:
#
#   <key>DESTINATIONS</key>
#   <string>{"incoming":"/Users/isaac/vault/incoming","links":"..."}</string>
#
# ── Run ────────────────────────────────────────────────────────────────────
#   source ~/.env.local
#   python3 bot.py
#
# Or as launchd service (loads plist env vars directly):
#   launchctl load ~/Library/LaunchAgents/com.user.link-bot.plist
