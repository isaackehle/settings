# Inbox Bot — configuration
# Copy this to config.local.env and fill in your values.

# Required: Telegram bot token from @BotFather
BOT_TOKEN=""

# Required: Your Telegram user ID (bot only responds to you)
# Get it from @userinfobot
ALLOWED_USER_ID=""

# Ollama endpoint (Mac mini runs this locally)
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="qwen3:14b"

# Optional: OpenRouter API key for cloud fallback (better summarization)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"

# Destinations: JSON map of short_name -> absolute directory path
# These appear as inline keyboard buttons when saving.
# "incoming" is the default catch-all (shown with an arrow).
DESTINATIONS='{
  "incoming": "~/vault/incoming",
  "links": "~/code/isaackehle/settings/saved-links",
  "notes": "~/vault/incoming"
}'
