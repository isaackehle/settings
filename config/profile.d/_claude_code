# Claude Code — route to local Ollama via Anthropic API shim
# (Ollama does not natively speak Anthropic API; use Continue.dev or Cline for full compatibility)

command -v claude >/dev/null 2>&1 || return 0

# Check if Ollama is running (port 11434)
if curl -s --max-time 2 http://localhost:11434/api/tags >/dev/null 2>&1; then
    export ANTHROPIC_API_KEY="sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
    export ANTHROPIC_BASE_URL="http://localhost:11434"
fi
