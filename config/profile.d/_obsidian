command -v opencode >/dev/null 2>&1 || return 0

# Use helpers.sh to detect the machine profile and pull the research model
if [[ -f "$SETTINGS_BASE/helpers.sh" ]]; then
    source "$SETTINGS_BASE/helpers.sh"
    _profile=$( _detect_profile )
    if [[ -n "$_profile" ]]; then
        _models_file="$SETTINGS_BASE/2-ai/profiles/$_profile/models.sh"
        if [[ -f "$_models_file" ]]; then
            source "$_models_file"
            _vault_model="${OPENCODE_AGENTS[research]}"
        fi
    fi
fi

# Fallback if detection fails
_vault_model="${_vault_model:-deepseek-r1-tools:8b-128k}"

alias vault="cd \"\$PRIMARY_VAULT\" && opencode --model $_vault_model"

unset _profile _models_file _vault_model
