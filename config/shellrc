# Shared preamble — installed to ~/.shellrc by setup.sh, sourced by bashrc and zshrc

# These are after the soft-links are set
export PROTON_LINK="$HOME/ProtonDrive"
export ONEDRIVE_LINK="$HOME/OneDrive"
export PRIMARY_VAULT="$ONEDRIVE_LINK/vault"
export SETTINGS_BASE="$HOME/code/isaackehle/settings"
export PATH="$HOME/.local/bin:$PATH"

# Load sensitive environment variables (not in git)
[ -f "$HOME/.env.local" ] && source "$HOME/.env.local"

# Load shared tool configs (installed by setup.sh)
for _f in "$HOME/.profile.d"/_*; do
    [ -s "$_f" ] && source "$_f"
done
unset _f
