{
  "mcpServers": {
    "apple-reminders": {
      "command": "/usr/local/bin/server-apple-reminders/apple-reminders-mcp"
    },
    "noteplan": {
      "command": "npx",
      "args": ["-y", "@noteplanco/noteplan-mcp"]
    },
    "ticktick": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/jen6/ticktick-mcp.git", "ticktick-mcp"]
    }
  }
}